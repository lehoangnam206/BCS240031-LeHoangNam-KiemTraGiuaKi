@model IEnumerable<Room_BCS240031>
@{
    ViewData["Title"] = "Danh sách phòng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div><h1 class="mb-1">Danh sách phòng trọ</h1><p class="text-muted mb-0">Quản lý phòng trọ - BCS240031</p></div>
    <a asp-action="Create" class="btn btn-primary">Thêm phòng</a>
</div>

<form method="get" class="card card-body mb-4 filter-panel">
    <div class="row g-3">
        <div class="col-md-3"><label class="form-label">Tên phòng</label><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Nhập một phần tên" /></div>
        <div class="col-md-3"><label class="form-label">Loại phòng</label><select name="roomTypeId" asp-items="ViewBag.RoomTypes" class="form-select"><option value="">Tất cả loại phòng</option></select></div>
        <div class="col-md-2"><label class="form-label">Trạng thái</label><select name="isAvailable" class="form-select"><option value="">Tất cả</option><option value="true" selected="@(ViewBag.IsAvailable is true ? "selected" : null)">Còn phòng</option><option value="false" selected="@(ViewBag.IsAvailable is false ? "selected" : null)">Đã thuê</option></select></div>
        <div class="col-md-2"><label class="form-label">Giá tối đa</label><input type="number" min="1" step="1000" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" /></div>
        <div class="col-md-2"><label class="form-label">Sắp xếp</label><select name="sort" class="form-select"><option value="price_asc" selected="@(ViewBag.Sort == "price_asc" ? "selected" : null)">Giá tăng dần</option><option value="price_desc" selected="@(ViewBag.Sort == "price_desc" ? "selected" : null)">Giá giảm dần</option><option value="area_desc" selected="@(ViewBag.Sort == "area_desc" ? "selected" : null)">Diện tích giảm dần</option></select></div>
    </div>
    <div class="mt-3"><button class="btn btn-dark">Tìm kiếm</button> <a asp-action="Index" class="btn btn-outline-secondary">Xóa điều kiện</a></div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Không tìm thấy phòng phù hợp với các điều kiện đã nhập.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead><tr><th>Ảnh</th><th>Tên phòng</th><th>Loại phòng</th><th class="text-end">Giá thuê</th><th class="text-end">Diện tích</th><th class="text-end">Giá/m²</th><th>Trạng thái</th><th></th></tr></thead>
            <tbody>
            @foreach (var room in Model)
            {
                var thumbnail = room.RoomImages.FirstOrDefault(i => i.IsThumbnail)?.ImageUrl;
                <tr>
                    <td>@if (thumbnail is null) { <span class="image-placeholder">Chưa có ảnh</span> } else { <img src="@thumbnail" class="room-thumb" alt="Ảnh @room.Name" /> }</td>
                    <td><strong>@room.Name</strong></td><td>@room.RoomType?.Name</td>
                    <td class="text-end">@room.Price.ToString("N0") đ</td><td class="text-end">@room.Area.ToString("N1") m²</td><td class="text-end">@((room.Price / room.Area).ToString("N0")) đ</td>
                    <td><span class="badge @(room.IsAvailable ? "text-bg-success" : "text-bg-secondary")">@(room.IsAvailable ? "Còn phòng" : "Đã thuê")</span></td>
                    <td class="text-nowrap"><a asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a> <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-outline-dark">Sửa</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
