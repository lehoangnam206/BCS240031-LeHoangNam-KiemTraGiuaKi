@model Room_BCS240031
@{ ViewData["Title"] = "Chỉnh sửa phòng"; }
<h1>Chỉnh sửa phòng @Model.Name</h1>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="card card-body form-card">
    <input asp-for="Id" type="hidden" />
    <partial name="_RoomForm" model="Model" />
    <div class="mt-4"><button class="btn btn-primary">Lưu thay đổi</button> <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Hủy</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
