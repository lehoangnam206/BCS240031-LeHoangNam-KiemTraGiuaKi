@model Room_BCS240031
@{ ViewData["Title"] = "Chi tiết phòng"; }
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1>@Model.Name</h1><span class="badge @(Model.IsAvailable ? "text-bg-success" : "text-bg-secondary")">@(Model.IsAvailable ? "Còn phòng" : "Đã thuê")</span></div><div><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Chỉnh sửa</a> <a asp-action="Index" class="btn btn-outline-secondary">Danh sách</a></div></div>
<div class="row g-4 mb-4">
    <div class="col-md-5"><div class="card card-body h-100"><dl class="row mb-0"><dt class="col-5">Loại phòng</dt><dd class="col-7">@Model.RoomType?.Name</dd><dt class="col-5">Giá thuê</dt><dd class="col-7">@Model.Price.ToString("N0") đ/tháng</dd><dt class="col-5">Diện tích</dt><dd class="col-7">@Model.Area.ToString("N1") m²</dd><dt class="col-5">Giá trên 1 m²</dt><dd class="col-7 fw-bold text-primary">@((Model.Price / Model.Area).ToString("N0")) đ/m²</dd><dt class="col-5">Mô tả</dt><dd class="col-7">@(Model.Description ?? "Không có")</dd></dl></div></div>
    <div class="col-md-7">
        @if (!Model.RoomImages.Any()) { <div class="alert alert-warning h-100">Phòng chưa có ảnh. Hãy thêm ảnh bằng đường dẫn bên dưới.</div> }
        else { <div class="row g-2">@foreach (var image in Model.RoomImages.OrderByDescending(i => i.IsThumbnail)) { <div class="col-sm-6"><div class="card image-card"><img src="@image.ImageUrl" class="card-img-top detail-image" alt="Ảnh phòng @Model.Name" /><div class="card-body py-2">@if (image.IsThumbnail) { <span class="badge text-bg-primary">Ảnh đại diện</span> } else { <form asp-action="SetThumbnail" asp-route-id="@image.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-primary">Chọn làm đại diện</button></form> }</div></div></div> }</div> }
    </div>
</div>
<div class="card card-body mb-3"><h2 class="h5">Thêm ảnh bằng đường dẫn</h2><form asp-action="AddImage" method="post" class="row g-2 align-items-end"><input type="hidden" name="roomId" value="@Model.Id" /><div class="col-md-8"><label class="form-label">URL ảnh</label><input type="url" name="imageUrl" required class="form-control" placeholder="https://..." /></div><div class="col-md-2"><div class="form-check mb-2"><input type="checkbox" name="isThumbnail" value="true" class="form-check-input" id="isThumbnail" /><label for="isThumbnail" class="form-check-label">Ảnh đại diện</label></div></div><div class="col-md-2"><button class="btn btn-dark w-100">Thêm ảnh</button></div></form></div>
