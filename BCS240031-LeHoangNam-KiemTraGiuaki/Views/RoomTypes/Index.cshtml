@model IEnumerable<RoomType_BCS240031>
@{ ViewData["Title"] = "Loại phòng"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1>Loại phòng</h1><a asp-action="Create" class="btn btn-primary">Thêm loại phòng</a></div>
<table class="table table-hover align-middle"><thead><tr><th>Tên loại</th><th>Mô tả</th><th>Số phòng</th><th></th></tr></thead><tbody>@foreach (var item in Model) { <tr><td class="fw-bold">@item.Name</td><td>@item.Description</td><td>@item.Rooms.Count</td><td class="text-end"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Sửa</a> <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa loại phòng này?')">Xóa</button></form></td></tr> }</tbody></table>
